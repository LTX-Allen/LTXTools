<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LTXTools.Views.FormatPage">
    <VerticalStackLayout Margin="30" Spacing="15">
        <Label Text="💾 磁盘格式化" FontSize="28" FontAttributes="Bold" TextColor="#1A3C5E" HorizontalOptions="Center"/>
        <Picker x:Name="cmbDrives" Title="请选择磁盘..."/>
        <Button x:Name="btnFormat" Text="💾 格式化磁盘" Clicked="btnFormat_Clicked" BackgroundColor="#E74C3C" TextColor="White" HeightRequest="45" FontAttributes="Bold"/>
        <Label x:Name="txtStatus" Text="✅ 就绪" FontSize="14" TextColor="#333"/>
    </VerticalStackLayout>
</ContentView>
