<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LTXTools.Views.ProcessGUIPage">
    <VerticalStackLayout Margin="30" Spacing="15">
        <Label Text="🖥️ GUI 进程管理器" FontSize="28" FontAttributes="Bold" TextColor="#1A3C5E" HorizontalOptions="Center"/>
        <Button x:Name="btnRefresh" Text="🔄 刷新" Clicked="btnRefresh_Clicked" BackgroundColor="#4A90D9" TextColor="White" HeightRequest="40"/>
        <ListView x:Name="gridProcesses" HeightRequest="300">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="{Binding ProcessName}" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding PID}" VerticalOptions="Center"/>
                            <Label Grid.Column="2" Text="{Binding Memory}" VerticalOptions="Center"/>
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Label x:Name="txtStatus" Text="✅ 就绪" FontSize="14" TextColor="#333"/>
    </VerticalStackLayout>
</ContentView>
