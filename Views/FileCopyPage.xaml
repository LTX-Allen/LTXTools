<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LTXTools.Views.FileCopyPage">
    <VerticalStackLayout Margin="30" Spacing="15">
        <Label Text="📁 文件复制" FontSize="28" FontAttributes="Bold" TextColor="#1A3C5E" HorizontalOptions="Center"/>
        <Label Text="源文件路径：" FontSize="16"/>
        <HorizontalStackLayout Spacing="10">
            <Entry x:Name="txtSource" Placeholder="选择源文件..." HorizontalOptions="FillAndExpand"/>
            <Button x:Name="btnBrowseSource" Text="浏览" Clicked="btnBrowseSource_Clicked" WidthRequest="80"/>
        </HorizontalStackLayout>
        <Label Text="目标路径：" FontSize="16"/>
        <HorizontalStackLayout Spacing="10">
            <Entry x:Name="txtDest" Placeholder="选择目标目录..." HorizontalOptions="FillAndExpand"/>
            <Button x:Name="btnBrowseDest" Text="浏览" Clicked="btnBrowseDest_Clicked" WidthRequest="80"/>
        </HorizontalStackLayout>
        <Button x:Name="btnCopy" Text="🚀 开始复制" Clicked="btnCopy_Clicked" BackgroundColor="#4A90D9" TextColor="White" HeightRequest="45" FontAttributes="Bold"/>
        <Label x:Name="txtStatus" Text="✅ 就绪" FontSize="14" TextColor="#333"/>
    </VerticalStackLayout>
</ContentView>
